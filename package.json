{
  "name": "v5x",
  "private": true,
  "packageManager": "bun@1.3.14",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "test": "turbo run test --filter=@v5x/cli",
    "dev": "turbo run dev",
    "cli": "bun packages/cli/src/index.ts",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck"
  },
  "devDependencies": {
    "prettier": "^3.8.3",
    "turbo": "^2.5.3",
    "typescript": "^5.9.3"
  }
}
