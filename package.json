{
  "name": "v5x",
  "private": true,
  "packageManager": "bun@1.3.14",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "overrides": {
    "esbuild": "^0.28.1",
    "js-yaml": "^4.2.0",
    "qs": "^6.15.2",
    "tar": "^7.5.16",
    "yaml": "^2.8.3"
  },
  "scripts": {
    "build": "turbo run build",
    "test": "turbo run test",
    "dev": "turbo run dev",
    "cli": "bun packages/cli/src/index.ts",
    "docs:dev": "bun run --cwd apps/docs dev",
    "docs:check": "bun run --cwd apps/docs check",
    "docs:export": "bun run --cwd apps/docs export",
    "docs:deploy": "bun run --cwd apps/docs deploy",
    "website:dev": "bun run --cwd apps/website dev",
    "website:check": "bun run --cwd apps/website check",
    "website:build": "bun run --cwd apps/website build",
    "website:deploy": "bun run --cwd apps/website deploy",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "oxlint packages apps --type-aware",
    "test:coverage": "turbo run build --filter=@v5x/serial --filter=@v5x/cli && bun test --coverage packages",
    "typecheck": "turbo run typecheck"
  },
  "devDependencies": {
    "oxlint": "^1.70.0",
    "oxlint-tsgolint": "^0.23.0",
    "prettier": "^3.8.3",
    "turbo": "^2.5.3",
    "typescript": "^5.9.3"
  },
  "patchedDependencies": {
    "front-matter@4.0.2": "patches/front-matter@4.0.2.patch"
  }
}
