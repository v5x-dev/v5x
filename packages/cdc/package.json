{
  "name": "@v5x/cdc",
  "version": "0.0.1",
  "description": "VEX CDC protocol packet codecs.",
  "license": "MIT",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/beanarchystudios/v5x.git",
    "directory": "packages/cdc"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "bun build ./src/index.ts --target bun --outfile ./dist/index.js && bunx tsc --emitDeclarationOnly",
    "lint": "bunx tsc --noEmit",
    "prepublishOnly": "bun run typecheck && bun run build",
    "typecheck": "bunx tsc --noEmit"
  },
  "engines": {
    "bun": ">=1.3.14"
  },
  "devDependencies": {
    "@types/bun": "^1.3.1"
  }
}
