{
  "name": "@v5x/cli",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "bin": {
    "v5x": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "bun build ./src/index.ts --target bun --outfile ./dist/index.js && chmod +x ./dist/index.js",
    "dev": "bun run ./src/index.ts",
    "lint": "bunx tsc --noEmit",
    "typecheck": "bunx tsc --noEmit"
  },
  "devDependencies": {
    "@types/bun": "^1.3.1"
  }
}
