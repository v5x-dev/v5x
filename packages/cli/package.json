{
  "name": "@v5x/cli",
  "version": "0.0.19",
  "description": "modern v5 development",
  "author": "beanarchystudios",
  "bin": {
    "cli": "./dist/index.js"
  },
  "files": ["dist", "README.md"],
  "type": "module",
  "scripts": {
    "postinstall": "bunli generate",
    "dev": "bun run src/index.ts",
    "build": "bunli build --outfile dist/index.js",
    "prepublishOnly": "bun run build",
    "test": "bun test",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@bunli/core": "latest",
    "@bunli/runtime": "^0.3.2",
    "@v5x/serial": "workspace:*",
    "bun-serialport": "^0.1.1",
    "cli-table": "^0.3.11",
    "pngjs": "^7.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@bunli/test": "latest",
    "@tsconfig/bun": "1.0.10",
    "@types/bun": "latest",
    "@types/cli-table": "^0.3.4",
    "@types/pngjs": "^6.0.5",
    "bunli": "latest",
    "typescript": "^5.0.0"
  },
  "bunli": {
    "entry": "./src/index.ts",
    "outDir": "./dist"
  }
}
