{
  "name": "@v5x/serial",
  "version": "0.5.6",
  "description": "implementation of the v5 serial protocol",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "scripts": {
    "build": "bun run clean && bun run build:dts && bun run build:esm && bun run build:cjs",
    "build:esm": "bun build ./src/index.ts --target browser --format esm --sourcemap=linked --outdir ./dist --entry-naming=index.js --external unzipit",
    "build:cjs": "bun build ./src/index.ts --target node --format cjs --sourcemap=linked --outdir ./dist --entry-naming=index.cjs --external unzipit",
    "build:dts": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint src --type-aware",
    "test": "bun test",
    "prepack": "bun run build",
    "clean": "rm -rf dist"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/v5x-dev/v5x.git",
    "directory": "packages/serial"
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "keywords": [
    "v5",
    "vex",
    "vex-robotics",
    "vex-v5",
    "serial",
    "protocol",
    "web-serial",
    "robotics",
    "pros",
    "vexide"
  ],
  "author": "qainguin <slimaster14@gmail.com>",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/v5x-dev/v5x/issues"
  },
  "homepage": "https://docs.v5x.dev/serial/overview",
  "devDependencies": {
    "@types/bun": "latest",
    "fflate": "^0.8.3"
  },
  "dependencies": {
    "@types/dom-serial": "^1.0.2",
    "neverthrow": "^8.2.0",
    "unzipit": "^2.0.3"
  }
}
