---
import { ArrowRight, Camera, Cpu, Upload, Wrench } from "lucide-astro";

const docsBase = "https://docs.v5x.dev";
const workflows = [
  { name: "project setup", href: `${docsBase}/cli/project-workflows`, Icon: Wrench },
  { name: "build and upload", href: `${docsBase}/cli/commands/upload`, Icon: Upload },
  { name: "brain inspection", href: `${docsBase}/cli/commands/devices`, Icon: Cpu },
  { name: "files and screenshots", href: `${docsBase}/serial/guides/manage-files`, Icon: Camera },
];
---

<section class="grid gap-3 pb-8 sm:grid-cols-2 lg:grid-cols-4" aria-label="Supported workflows">
  {workflows.map(({ name, href, Icon }) => (
    <a class="flex min-h-12 items-center justify-between gap-3 rounded-lg border border-zinc-200 bg-black/[0.03] px-3 py-2.5 text-[0.88rem] font-medium text-zinc-600 no-underline hover:border-zinc-300 hover:bg-black/[0.06] hover:text-zinc-900 focus-visible:outline-3 focus-visible:outline-offset-2 focus-visible:outline-indigo-500 dark:border-white/10 dark:bg-white/[0.035] dark:text-zinc-300 dark:hover:border-white/20 dark:hover:bg-white/[0.07] dark:hover:text-white dark:focus-visible:outline-[#b8baff]" href={href}>
      <span class="flex items-center gap-2.5"><Icon class="shrink-0 text-zinc-400 dark:text-zinc-500" size={16} stroke-width={1.8} aria-hidden="true" />{name}</span>
      <ArrowRight class="shrink-0 text-zinc-400 dark:text-zinc-600" size={14} stroke-width={1.9} aria-hidden="true" />
    </a>
  ))}
</section>
